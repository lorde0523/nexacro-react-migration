<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- [MIGRATION] AS-IS: Nexcore BoardDAO XML -->
<!-- [TO-BE]: MyBatis Mapper XML -->

<mapper namespace="com.migration.nexacro.mapper.BoardMapper">

    <resultMap id="BoardResultMap" type="BoardDTO">
        <id property="boardId" column="board_id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="writer" column="writer"/>
        <result property="viewCount" column="view_count"/>
        <result property="attachCount" column="attach_count"/>
        <result property="useYn" column="use_yn"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 게시글 목록 조회 (Nexacro fn_search 대응) -->
    <select id="findAll" parameterType="SearchCondition" resultMap="BoardResultMap">
        SELECT board_id, title, writer, view_count, attach_count, use_yn, created_at, updated_at
        FROM boards
        <where>
            AND use_yn = 'Y'
            <if test="title != null and title != ''">
                AND title LIKE CONCAT('%', #{title}, '%')
            </if>
            <if test="writer != null and writer != ''">
                AND writer LIKE CONCAT('%', #{writer}, '%')
            </if>
            <if test="startDate != null and startDate != ''">
                AND DATE(created_at) >= #{startDate}
            </if>
            <if test="endDate != null and endDate != ''">
                AND DATE(created_at) &lt;= #{endDate}
            </if>
        </where>
        ORDER BY board_id DESC
    </select>

    <!-- 게시글 상세 조회 -->
    <select id="findById" resultMap="BoardResultMap">
        SELECT board_id, title, content, writer, view_count, attach_count, use_yn, created_at, updated_at
        FROM boards
        WHERE board_id = #{boardId} AND use_yn = 'Y'
    </select>

    <!-- 게시글 등록 (Nexacro INSERT 대응) -->
    <insert id="insert" parameterType="BoardDTO" useGeneratedKeys="true" keyProperty="boardId">
        INSERT INTO boards (title, content, writer, use_yn)
        VALUES (#{title}, #{content}, #{writer}, 'Y')
    </insert>

    <!-- 게시글 수정 (Nexacro UPDATE 대응) -->
    <update id="update" parameterType="BoardDTO">
        UPDATE boards
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="writer != null">writer = #{writer},</if>
            updated_at = CURRENT_TIMESTAMP
        </set>
        WHERE board_id = #{boardId}
    </update>

    <!-- 게시글 삭제 (논리 삭제 - Nexacro DELETE 대응) -->
    <update id="deleteById">
        UPDATE boards SET use_yn = 'N', updated_at = CURRENT_TIMESTAMP
        WHERE board_id = #{boardId}
    </update>

    <!-- 조회수 증가 -->
    <update id="incrementViewCount">
        UPDATE boards SET view_count = view_count + 1 WHERE board_id = #{boardId}
    </update>

</mapper>
